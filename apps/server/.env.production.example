# Copy to .env.production and fill in real values. Never commit .env.production.
# In hosted environments (e.g. Render) set these via the provider's dashboard
# instead of shipping the file.
NODE_ENV=production
PORT=4000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.xxx.mongodb.net/health-portal
CORS_ORIGIN=https://your-frontend.vercel.app
