{
  "name": "@health-portal/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env.development src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod-local": "node --env-file=.env.production dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx --env-file=.env.development src/seed.ts",
    "seed:prod": "tsx --env-file=.env.production src/seed.ts"
  },
  "dependencies": {
    "@health-portal/shared": "workspace:*",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "mongoose": "^8.13.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
