    {
      "name": "Negative tests",
      "description": "Error-path checks — run after the happy path.",
      "item": [
        {
          "name": "Portal without session → 401",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Clear cookies for baseUrl so this request is truly unauthenticated.",
                  "const url = pm.collectionVariables.get('baseUrl');",
                  "const jar = pm.cookies.jar();",
                  "jar.clear(url, () => {});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 401', () => pm.response.to.have.status(401));",
                  "pm.test('NOT_AUTHENTICATED envelope', () => {",
                  "  const b = pm.response.json();",
                  "  pm.expect(b.success).to.equal(false);",
                  "  pm.expect(b.error.code).to.equal('NOT_AUTHENTICATED');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/portal/summary", "host": ["{{baseUrl}}"], "path": ["api", "portal", "summary"] }
          }
        },
        {
          "name": "Login with wrong password → 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 401', () => pm.response.to.have.status(401));",
                  "pm.test('INVALID_CREDENTIALS envelope', () => {",
                  "  const b = pm.response.json();",
                  "  pm.expect(b.error.code).to.equal('INVALID_CREDENTIALS');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{loginEmail}}\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        },
